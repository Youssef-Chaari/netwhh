    <DTS:Executable
      DTS:refId="Package\SQL_Load_DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="SQL_Load_DimDate"
      DTS:DTSID="{9877D29C-08B2-462A-AF8B-9A8F78A3CBE6}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Load_DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{325F8785-7390-4468-8A60-92A3A5EA760C}"
          SQLTask:SqlStatementSource="USE AdventureWorksDW2025_ETL;&#xA;GO&#xA;&#xA;DECLARE @StartDate date = (&#xA;    SELECT DATEADD(DAY, 1, MAX(FullDate)) &#xA;    FROM dw.DimDate&#xA;);&#xA;DECLARE @EndDate   date = '2016-12-31';  -- nouvelle fin de période par ex.&#xA;&#xA;IF @StartDate IS NULL&#xA;    SET @StartDate = '2010-01-01';  -- si DimDate est vide (cas initial)&#xA;&#xA;;WITH Dates AS (&#xA;    SELECT @StartDate AS FullDate&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, FullDate)&#xA;    FROM Dates&#xA;    WHERE FullDate &lt; @EndDate&#xA;)&#xA;INSERT INTO dw.DimDate&#xA;    (DateKey, FullDate, CalendarYear, MonthNumberOfYear, EnglishMonthName,&#xA;     DayNumberOfMonth, DayNameOfWeek, IsWeekend, CalendarQuarter)&#xA;SELECT&#xA;    CAST(CONVERT(char(8), FullDate, 112) AS int) AS DateKey,&#xA;    FullDate,&#xA;    YEAR(FullDate)             AS CalendarYear,&#xA;    MONTH(FullDate)            AS MonthNumberOfYear,&#xA;    DATENAME(MONTH, FullDate)  AS EnglishMonthName,&#xA;    DAY(FullDate)              AS DayNumberOfMonth,&#xA;    DATENAME(WEEKDAY, FullDate) AS DayNameOfWeek,&#xA;    CASE WHEN DATENAME(WEEKDAY, FullDate) IN ('Saturday','Sunday') THEN 1 ELSE 0 END AS IsWeekend,&#xA;    DATEPART(QUARTER, FullDate) AS CalendarQuarter&#xA;FROM Dates&#xA;OPTION (MAXRECURSION 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
