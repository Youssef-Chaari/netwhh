                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    a.AddressID                 AS GeographyKey,
    a.City                      AS City,
    sp.Name                     AS StateProvinceName,
    cr.Name                     AS EnglishCountryRegionName,
    a.PostalCode,
    sp.StateProvinceCode        AS StateProvinceCode,
    cr.CountryRegionCode        AS CountryRegionCode
FROM Person.Address AS a
JOIN Person.StateProvince AS sp
    ON a.StateProvinceID = sp.StateProvinceID
JOIN Person.CountryRegion AS cr
    ON sp.CountryRegionCode = cr.CountryRegionCode;</property>
